# Copy this file to `.env` and fill real values per environment.
# Never commit real secrets.
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/apexlinkgroup
JWT_SECRET=add_your_secret_here
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173
# Optional comma-separated list of extra allowed CORS origins
CORS_ORIGINS=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=lkr

# PayHere Checkout API (merchant secret stays backend-only)
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_MODE=sandbox
# Must be publicly reachable by PayHere; localhost URLs do not receive notifications.
PAYHERE_NOTIFY_URL=https://api.example.com/api/payments/payhere/notify

# Optional business metadata shown in invoice/packing documents
BUSINESS_NAME=APEX LINK GROUP
BUSINESS_EMAIL=support@apexlinkgroup.com
BUSINESS_PHONE=+1 (555) 123-4567
BUSINESS_ADDRESS=One Apex Plaza, Suite 400, Global Trade District, San Francisco, CA 94110
BUSINESS_WEBSITE=http://localhost:5173

# Email / SMTP
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Operations / monitoring
SERVICE_NAME=apex-backend
SENTRY_DSN=
ALERT_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
UPTIME_URLS=
UPTIME_TIMEOUT_MS=8000

# Backups / performance
DB_BACKUP_DIR=./backups
ALLOW_DB_RESTORE=false
LOAD_TEST_BASE_URL=http://127.0.0.1:5000
LOAD_TEST_REQUESTS=50
LOAD_TEST_CONCURRENCY=10

# Growth / marketing
NEWSLETTER_WEBHOOK_URL=
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
MAILCHIMP_SERVER_PREFIX=
DEFAULT_CURRENCY=LKR
ABANDONED_CART_SEND_LIMIT=50
ABANDONED_CART_MIN_AGE_MINUTES=60
